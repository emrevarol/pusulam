generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  displayName  String
  passwordHash String
  avatar       String?
  bio          String?
  oyHakki      Int      @default(50)   // Oy hakki (tek birim)
  reputation   Float    @default(0)    // Kalibrasyon skoru
  streak       Int      @default(0)    // Gunluk tahmin serisi
  lastActiveAt DateTime @default(now())
  role         String   @default("USER") // USER, PRO, ADMIN
  plan         String   @default("FREE") // FREE, PREMIUM
  planExpiresAt DateTime?
  stripeCustomerId    String?  @unique
  stripeSubscriptionId String? @unique
  streakFreezes Int      @default(0) // remaining streak freezes this month
  trialUsed     Boolean  @default(false) // has user used free trial
  country      String   @default("TR") // TR, DE, FR, BR, GB, ES, EG
  referralCode String?  @unique
  referredById String?
  referredBy   User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]   @relation("Referrals")
  createdAt    DateTime @default(now())

  markets      Market[]
  trades       Trade[]
  positions    Position[]
  comments     Comment[]
  commentVotes CommentVote[]
  badges           UserBadge[]
  predictions      Prediction[]
  conversations    Conversation[]
  dailyPredictions DailyPrediction[]
  creditPurchases  CreditPurchase[]
  suggestions      MarketSuggestion[]
  referralRewards  ReferralReward[]
  notifications    Notification[]
  friendRequestsSent     Friendship[] @relation("FriendRequester")
  friendRequestsReceived Friendship[] @relation("FriendReceiver")

  @@index([reputation])
  @@index([oyHakki])
}

model Market {
  id              String    @id @default(cuid())
  title           String
  description     String
  titleTranslations       Json?  // { en: "...", es: "...", fr: "...", ... }
  descriptionTranslations Json?  // { en: "...", es: "...", fr: "...", ... }
  category        String
  country         String    @default("GLOBAL") // TR, DE, FR, BR, GB, ES, EG, GLOBAL
  slug            String    @unique
  status          String    @default("OPEN") // OPEN, HALTED, CLOSED, RESOLVED
  resolutionDate  DateTime
  resolvedAt      DateTime?
  resolvedOutcome String?   // YES, NO
  haltedAt        DateTime?
  haltReason      String?
  earlyResolution Boolean   @default(false)
  liveData        Json?     // { price: "71,293", label: "Bitcoin", source: "CoinGecko", updatedAt: "..." }
  recentNews      Json?     // [{ title: "...", url: "...", source: "Reuters", date: "..." }, ...]
  yesPool         Float     @default(100)
  noPool          Float     @default(100)
  volume          Float     @default(0)
  traderCount     Int       @default(0)
  featured        Boolean   @default(false)
  premiumOnly     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  trades       Trade[]
  positions    Position[]
  comments     Comment[]
  predictions  Prediction[]
  conversations Conversation[]
  priceHistory PriceHistory[]

  @@index([status, category])
  @@index([status, volume])
  @@index([slug])
}

model Trade {
  id        String   @id @default(cuid())
  direction String   // BUY, SELL
  side      String   // YES, NO
  shares    Float
  price     Float
  cost      Float
  weight    Int      @default(1) // legacy, always 1
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])

  @@index([userId])
  @@index([marketId])
  @@index([createdAt])
}

model Position {
  id       String @id @default(cuid())
  side     String // YES, NO
  shares   Float  @default(0)
  avgPrice Float  @default(0)

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])

  @@unique([userId, marketId, side])
}

model Prediction {
  id          String   @id @default(cuid())
  probability Float    // 0.0 - 1.0 kullanicinin tahmini
  reasoning   String?  // Neden boyle dusunuyorsun?
  score       Float?   // Brier/log skoru (cozuldukten sonra)
  createdAt   DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])

  @@unique([userId, marketId])
  @@index([score])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])
  votes    CommentVote[]

  @@index([marketId])
}

model CommentVote {
  id    String @id @default(cuid())
  value Int    // +1 or -1

  userId    String
  user      User    @relation(fields: [userId], references: [id])
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  tier        String // BRONZE, SILVER, GOLD, PLATINUM
  requirement String // JSON: kosul aciklamasi

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  earnedAt DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model Conversation {
  id        String   @id @default(cuid())
  title     String?
  marketId  String?
  market    Market?  @relation(fields: [marketId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ChatMessage[]

  @@index([userId])
  @@index([marketId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  role           String   // "user" or "assistant"
  content        String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([conversationId])
}

model DailyPrediction {
  id     String   @id @default(cuid())
  date   DateTime @db.Date
  count  Int      @default(0)
  userId String
  user   User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model CreditPurchase {
  id              String    @id @default(cuid())
  amount          Int       // credits purchased
  priceUsd        Float     // amount paid in USD
  stripeSessionId String    @unique
  stripePaymentId String?
  status          String    @default("PENDING") // PENDING, COMPLETED, FAILED
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([userId])
  @@index([stripeSessionId])
}

model Friendship {
  id        String   @id @default(cuid())
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requesterId String
  requester   User @relation("FriendRequester", fields: [requesterId], references: [id])
  receiverId  String
  receiver    User @relation("FriendReceiver", fields: [receiverId], references: [id])

  @@unique([requesterId, receiverId])
  @@index([receiverId, status])
}

model ReferralReward {
  id        String   @id @default(cuid())
  amount    Int
  createdAt DateTime @default(now())

  referrerId String
  referrer   User   @relation(fields: [referrerId], references: [id])
  referredId String @unique // one reward per referred user

  @@index([referrerId])
}

model PriceHistory {
  id        String   @id @default(cuid())
  probability Float  // YES probability (0.0 - 1.0)
  source    String   @default("TRADE") // TRADE, POLYMARKET, MANUAL
  createdAt DateTime @default(now())

  marketId String
  market   Market @relation(fields: [marketId], references: [id])

  @@index([marketId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // FRIEND_REQUEST, FRIEND_ACCEPTED, MARKET_RESOLVED, COMMENT_REPLY, BADGE_EARNED, PAYOUT
  title     String
  body      String
  link      String?  // URL to navigate to
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

model MarketSuggestion {
  id              String    @id @default(cuid())
  source          String    // POLYMARKET, NEWS_AI, MANUAL, USER
  sourceId        String?   // External market ID (dedup key)
  titleTr         String
  titleEn         String?
  descriptionTr   String
  descriptionEn   String?
  category        String
  suggestedDate   DateTime  // Suggested resolution date
  probability     Float?    // Current probability from source
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectReason    String?
  reviewedAt      DateTime?
  reviewedById    String?
  suggestedById   String?
  suggestedBy     User?     @relation(fields: [suggestedById], references: [id])
  createdAt       DateTime  @default(now())

  @@unique([source, sourceId])
  @@index([status])
  @@index([suggestedById])
}
